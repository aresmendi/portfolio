---
const categories = [
  {
    name: "Backend",
    skills: ["Java", "Python"],
  },
  {
    name: "Datos & Automatización",
    skills: ["Selenium", "Playwright", "Requests", "SQL"],
  },
  {
    name: "Herramientas",
    skills: ["Git", "Docker"],
  },
];
---

<section id="skills" class="pb-20">
  <h2 class="text-2xl font-semibold mb-6">Skills</h2>

  <div class="flex flex-col gap-6">
    {categories.map((category) => (
      <div>
        <h3 class="text-sm font-medium text-neutral-500 uppercase tracking-wider mb-3">
          {category.name}
        </h3>
        <ul class="flex flex-wrap gap-2">
          {category.skills.map((skill) => (
            <li class="px-3 py-1.5 text-sm rounded-lg border border-neutral-700 text-neutral-300">
              {skill}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
