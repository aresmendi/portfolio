---
const links = [
  { label: "Inicio",    href: "#inicio" },
  { label: "Sobre mí",  href: "#sobre-mi" },
  { label: "Proyectos", href: "#proyectos" },
  { label: "Skills",    href: "#skills" },
  { label: "Contacto",  href: "#contacto" },
];
---

<header class="sticky top-0 z-10 backdrop-blur-sm border-b border-neutral-800/60">
  <nav class="px-10 h-14 flex items-center justify-between">
    <a href="#inicio" class="font-semibold text-white hover:text-indigo-400 transition-colors">
      Ares
    </a>

    <ul class="flex items-center gap-6">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm text-neutral-400 hover:text-white transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
